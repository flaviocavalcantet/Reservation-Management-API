{
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "reservation-events",
    "GroupId": "reservation-consumer-group"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RetryPolicy": {
    "MaxRetryAttempts": 5,
    "DelayBetweenRetries": "00:00:02"
  },
  "Idempotency": {
    "StoreConnectionString": "YourConnectionStringHere"
  }
}