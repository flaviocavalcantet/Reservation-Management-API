# Copy this file to .env and fill in real values for your environment.
# .env is gitignored - never commit real secrets.
# Docker Compose loads .env automatically for ${VAR} substitution in
# docker-compose.yml / docker-compose.override.yml / docker-compose.prod.yml.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ReservationManagement

# --- JWT Authentication ---
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ISSUER=ReservationAPI
JWT_AUDIENCE=ReservationWebApp
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# --- Auth0 (OIDC) ---
# Optional. Leave blank to disable the Auth0 authentication scheme.
AUTH0_AUTHORITY=
AUTH0_AUDIENCE=

# Note: docker-compose.prod.yml requires POSTGRES_PASSWORD and JWT_SECRET_KEY
# to be set (no defaults) - do not use the placeholder values above in production.
